{
  "name": "dragon-savings-redesign",
  "version": "2.0.0",
  "private": true,
  "description": "Static redesign for Dragon Savings and Credit Cooperative Limited.",
  "scripts": {
    "format:check": "prettier --check index.html app.js",
    "lint:html": "html-validate index.html",
    "lint:css": "stylelint style.css",
    "lint:js": "eslint app.js",
    "lint": "npm run format:check && npm run lint:html && npm run lint:css && npm run lint:js"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "eslint": "latest",
    "globals": "latest",
    "html-validate": "latest",
    "prettier": "latest",
    "stylelint": "latest",
    "stylelint-config-standard": "latest"
  }
}
